@Controller // 요청 / 응답 제어 역할 명시 + Bean 등록
@RequestMapping("todo") // "/todo" 로 시작하는 모든 요청 매핑
public class TodoController {

	@Autowired // 등록된 Bean 중 같은 타입이거나 상속관계 DI (의존성) 주입
	private TodoService service;
	
	
	
	
}
